local function addBtn(tab, x, y, w, textFunc, callback)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(0, w or 180, 0, 30)
    b.Position = UDim2.new(0, x, 0, y)
    b.BackgroundColor3 = Color3.fromRGB(56, 56, 70)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 16
    b.TextColor3 = Color3.new(1,1,1)
    b.Text = typeof(textFunc)=='function' and textFunc() or textFunc
    b.Parent = tab
    b.BorderSizePixel = 0
    b.MouseButton1Click:Connect(function()
        callback(b)
        if typeof(textFunc)=='function' then
            b.Text = textFunc()
        end
    end)
    return b
end
local function addLabel(tab, x, y, w, text)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0,w or 220,0,24)
    l.Position = UDim2.new(0,x,0,y)
    l.Text = text
    l.BackgroundTransparency = 1
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.Font = Enum.Font.Gotham
    l.TextSize = 15
    l.TextColor3 = Color3.fromRGB(100,227,255)
    l.Parent = tab
    return l
end

